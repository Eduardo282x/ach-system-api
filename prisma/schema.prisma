generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                 Int                 @id @default(autoincrement())
  name               String
  username           String
  password           String
  role               Role
  email              String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  deleted            Boolean             @default(false)
  cashDrawerSessions CashDrawerSession[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
}

model Clients {
  id        Int       @id @default(autoincrement())
  fullName  String
  identify  String    @default("") @unique
  phone     String    @default("")
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  invoices  Invoice[]
}

model ExchangeRate {
  id        Int              @id @default(autoincrement())
  name      String
  currency  ExchangeRateType
  rate      Decimal
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model TypePayment {
  id             Int             @id @default(autoincrement())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  paymentDetails PaymentDetail[]
}

model Product {
  id               Int                 @id @default(autoincrement())
  name             String
  presentation     String
  barcode          String              @unique
  price            Decimal
  currency         ExchangeRateType    @default(USD)
  stock            Int                 @default(0)
  isDetail         Boolean             @default(false)
  parentId         Int?
  unitsDetail      Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @default(now()) @updatedAt
  deleted          Boolean             @default(false)
  historyMovements InventoryMovement[]
  invoiceItems     InvoiceItem[]
  productParent    Product?            @relation("ConvertUnits", fields: [parentId], references: [id])
  productChild     Product[]           @relation("ConvertUnits")

  @@index([parentId])
}

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  quantity  Int
  type      MovementType
  reason    String?
  userId    Int
  createdAt DateTime     @default(now())
  product   Product      @relation(fields: [productId], references: [id])
  user      Users        @relation(fields: [userId], references: [id])
}

model Invoice {
  id              Int               @id @default(autoincrement())
  invoiceNumber   String            @unique
  totalAmountBs   Decimal
  exchangeRateUsd Decimal
  exchangeRateEur Decimal
  totalAmountUsd  Decimal
  totalReceivedBs Decimal
  totalChangeBs   Decimal
  status          InvoiceStatus     @default(PAID)
  userId          Int
  customerId      Int
  sessionId       Int
  createdAt       DateTime          @default(now())
  customer        Clients           @relation(fields: [customerId], references: [id])
  session         CashDrawerSession @relation(fields: [sessionId], references: [id])
  user            Users             @relation(fields: [userId], references: [id])
  items           InvoiceItem[]
  paymentDetails  PaymentDetail[]
}

model InvoiceItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  productId Int
  unitPrice Decimal
  quantity  Int
  subtotal  Decimal
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model PaymentDetail {
  id             Int              @id @default(autoincrement())
  invoiceId      Int
  paymentTypeId  Int
  amountReceived Decimal          @default(0)
  amountChange   Decimal          @default(0)
  amountNet      Decimal          @default(0)
  amountNetBs    Decimal
  currency       ExchangeRateType
  denominations  Json?
  invoice        Invoice          @relation(fields: [invoiceId], references: [id])
  paymentType    TypePayment      @relation(fields: [paymentTypeId], references: [id])
}

model CurrencyDenomination {
  id       Int              @id @default(autoincrement())
  currency ExchangeRateType
  value    Decimal
  active   Boolean          @default(true)
}

model CashDrawerSession {
  id             Int           @id @default(autoincrement())
  userId         Int
  cashDrawerId   Int
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  openingBalance Decimal
  closingBalance Decimal?
  totalSales     Decimal       @default(0)
  totalInUsd     Decimal       @default(0)
  totalInBs      Decimal       @default(0)
  status         SessionStatus @default(OPEN)
  user           Users         @relation(fields: [userId], references: [id])
  cashDrawer     CashDrawer    @relation(fields: [cashDrawerId], references: [id])
  invoices       Invoice[]
}

model CashDrawer {
  id                 Int                 @id @default(autoincrement())
  name               String
  cashDrawerSessions CashDrawerSession[]
}

enum Role {
  ADMIN
  CAJERO
  SUPERVISOR
}

enum ExchangeRateType {
  BS
  USD
  EUR
}

enum MovementType {
  SALE
  RESTOCK
  CONVERSION
  ADJUSTMENT
  RETURN
}

enum InvoiceStatus {
  PAID
  PENDING
  CANCELLED
}

enum SessionStatus {
  OPEN
  CLOSED
}
